{
  "name": "mega",
  "version": "5.2.0",
  "description": "High performance multi-device whatsapp bot",
  "type": "module",
  "main": "index.js",
  "directories": {
    "lib": "lib",
    "data": "data",
    "plugins": "plugins"
  },
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc && cp package.json dist/ && cp -r assets dist/",
    "dev": "tsc --watch & nodemon --watch dist dist/index.js",
    "setup": "npm run build && npm run reset-data",
    "start:optimized": "node --max-old-space-size=512 --optimize-for-size --gc-interval=100 dist/index.js",
    "reset-session": "node --input-type=module -e \"import fs from 'fs'; fs.rmSync('./session', {recursive:true, force:true}); console.log('Session cleared!')\"",
    "clean": "rm -rf dist/",
    "rebuild": "npm run clean && npm run build",
    "lint": "npx eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "mocha",
    "test:unit": "mocha test/unit/**/*.test.ts",
    "test:integration": "mocha test/integration/**/*.test.ts",
    "reset-data": "node dist/reset-data.js",
    "start:fresh": "npm run reset-data && npm run start"
  },
  "keywords": [
    "termux-whatsapp-bot",
    "whatsapp-bot",
    "whatsapp-api",
    "baileys-bot",
    "whatsApp",
    "mega-bot",
    "mega-md",
    "multi-device",
    "mega-ai"
  ],
  "homepage": "https://github.com/GlobalTechInfo/MEGA-MD",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GlobalTechInfo/MEGA-MD.git"
  },
  "bugs": {
    "url": "https://github.com/GlobalTechInfo/MEGA-MD/issues"
  },
  "license": "MIT",
  "author": "GlobalTechInfo",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "acrcloud": "^1.4.0",
    "api-qasim": "^3.2.10",
    "awesome-phonenumber": "^5.9.0",
    "axios": "^1.8.4",
    "better-sqlite3": "^12.5.0",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "file-type": "^19.6.0",
    "form-data": "^4.0.1",
    "fs-extra": "^11.2.0",
    "gspeak": "^0.0.3",
    "human-readable": "^0.2.1",
    "libphonenumber-js": "^1.11.18",
    "megajs": "^1.3.9",
    "moment-timezone": "^0.5.43",
    "mongoose": "^9.0.2",
    "mumaker": "^2.0.0",
    "mysql2": "^3.16.0",
    "node-cache": "^5.1.2",
    "node-fetch": "^3.3.2",
    "node-webpmux": "^3.1.0",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "ruhend-scraper": "^9.0.8",
    "sharp": "^0.34.0",
    "simple-git": "^3.30.0",
    "stickers-formatter": "^0.0.1",
    "syntax-error": "^1.4.0",
    "yt-search": "^2.12.1",
    "typescript": "^5.0.0"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "yargs-parser": "^21.1.1"
  },
  "contributors": [
    {
      "name": "Qasim Ali",
      "role": "Lead Developer"
    },
    {
      "name": "GlobalTechInfo",
      "role": "Maintainer"
    }
  ],
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "chai": "^6.2.2",
    "eslint": "^10.0.2",
    "madge": "^8.0.0",
    "mocha": "^11.7.5",
    "ts-mocha": "^11.1.0",
    "ts-unused-exports": "^11.0.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "ts-node": "^10.9.2"
  }
}