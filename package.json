{
  "name": "mega",
  "version": "5.2.0",
  "description": "High performance multi-device whatsapp bot",
  "type": "module",
  "main": "index.js",
  "directories": {
    "lib": "lib",
    "data": "data",
    "plugins": "plugins"
  },
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc && cp package.json dist/ && cp -r assets dist/ && cp -r data dist/",
    "dev": "tsc --watch & nodemon --watch dist dist/index.js",
    "setup": "npm install && npm run build",
    "start:optimized": "node --max-old-space-size=512 --optimize-for-size --gc-interval=100 dist/index.js",
    "reset-session": "node -e \"require('fs').rmSync('./session', {recursive:true, force:true}); console.log('Session cleared!')\"",
    "clean": "rm -rf dist/",
    "rebuild": "npm run clean && npm run build",
    "lint": "npx eslint . --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "termux-whatsapp-bot",
    "whatsapp-bot",
    "whatsapp-api",
    "baileys-bot",
    "whatsApp",
    "mega-bot",
    "mega-md",
    "multi-device",
    "mega-ai"
  ],
  "homepage": "https://github.com/GlobalTechInfo/MEGA-MD",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GlobalTechInfo/MEGA-MD.git"
  },
  "bugs": {
    "url": "https://github.com/GlobalTechInfo/MEGA-MD/issues"
  },
  "license": "MIT",
  "author": "GlobalTechInfo",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "acrcloud": "^1.4.0",
    "api-qasim": "^4.0.1",
    "awesome-phonenumber": "^5.9.0",
    "axios": "^1.8.4",
    "better-sqlite3": "^12.5.0",
    "chalk": "^5.6.2",
    "cheerio": "^1.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "file-type": "^19.6.0",
    "form-data": "^4.0.1",
    "fs-extra": "^11.2.0",
    "gtts": "^0.2.1",
    "human-readable": "^0.2.1",
    "libphonenumber-js": "^1.11.18",
    "megajs": "^1.3.9",
    "moment-timezone": "^0.5.43",
    "mongoose": "^9.0.2",
    "mumaker": "^2.0.0",
    "mysql2": "^3.16.0",
    "node-cache": "^5.1.2",
    "node-fetch": "^3.3.2",
    "node-webpmux": "^3.1.0",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "ruhend-scraper": "^9.0.8",
    "sharp": "^0.32.6",
    "simple-git": "^3.30.0",
    "stickers-formatter": "^0.0.1",
    "syntax-error": "^1.4.0",
    "yt-search": "^2.12.1"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "yargs-parser": "^21.1.1",
    "gtts": {
      "request": {
        "form-data": "^4.0.1",
        "qs": "^6.14.1",
        "tough-cookie": "^4.1.3"
      }
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "contributors": [
    {
      "name": "Qasim Ali",
      "role": "Lead Developer"
    },
    {
      "name": "GlobalTechInfo",
      "role": "Maintainer"
    }
  ],
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "madge": "^8.0.0",
    "ts-unused-exports": "^11.0.1"
  }
}